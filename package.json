{
  "name": "ruby-html-tag",
  "displayName": "ruby-html-tag",
  "description": "Wrap selections in <ruby> tags",
  "publisher": "fasiha",
  "license": "Unlicense",
  "version": "2.0.0",
  "repository": {
    "url": "https://github.com/fasiha/vscode-ruby-html-tag"
  },
  "engines": {
    "vscode": "^1.61.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ruby-html-tag.addRubyRtTags",
    "onCommand:ruby-html-tag.copyWithoutRtOnlyRuby"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ruby-html-tag.addRubyRtTags",
        "title": "Add Ruby and Rt Tags"
      },
      {
        "command": "ruby-html-tag.copyWithoutRtOnlyRuby",
        "title": "Copy Without Rt Tags (Only Ruby Text)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.1.4",
    "@types/mocha": "^9.0.0",
    "@types/node": "14.x",
    "@types/vscode": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.1.0",
    "glob": "^7.1.7",
    "mocha": "^11.7.5",
    "typescript": "^4.4.4"
  }
}